  <metadata>
    <id>SteamKit2</id>
    <version>3.3.1</version>
    <authors>SteamKit2</authors>
    <license type="expression">LGPL-2.1-only</license>
    <licenseUrl>https://licenses.nuget.org/LGPL-2.1-only</licenseUrl>
    <icon>steamkit_logo_128.png</icon>
    <readme>description.md</readme>
    <projectUrl>https://github.com/SteamRE/SteamKit</projectUrl>
    <description>.NET library that aims to interoperate with the Steam network.</description>
    <releaseNotes>Release notes are available at https://github.com/SteamRE/SteamKit/releases/tag/3.3.1</releaseNotes>
    <tags>steamkit sk2 steam valve dota dota2 csgo</tags>
    <repository type="git" url="https://github.com/SteamRE/SteamKit" commit="740d5013bc56ed81e0aa708d5a840fb4d7d080af" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.Win32.Registry" version="5.0.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Hashing" version="9.0.8" exclude="Build,Analyzers" />
        <dependency id="ZstdSharp.Port" version="0.8.6" exclude="Build,Analyzers" />
        <dependency id="protobuf-net" version="3.2.56" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
